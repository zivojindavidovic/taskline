# =============================================================================
# Taskline — self-hosted environment
# Copy to .env next to docker-compose.yml:  cp .env.docker.example .env
# =============================================================================

# Image to run (override with your own tag if you build it yourself)
TASKLINE_IMAGE=zivojindavidovic/taskline:latest

# Host port nginx is published on
HTTP_PORT=80

# --- Application -------------------------------------------------------------
APP_NAME=Taskline
APP_ENV=production
APP_DEBUG=false
# Leave APP_KEY empty and one is generated + persisted on first start,
# or set your own:  docker compose run --rm app php artisan key:generate --show
APP_KEY=
# Public URL users hit (used for links/emails). Set to your domain or http://SERVER_IP
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- Database (postgres service) --------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=taskline
DB_USERNAME=taskline
DB_PASSWORD=change-me-strong-password

# --- Drivers -----------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
# sync: queued work (if any is ever added) runs inline in the request, so no
# separate queue worker container is needed. All broadcast events are
# ShouldBroadcastNow (synchronous) and mail is sent synchronously anyway.
QUEUE_CONNECTION=sync
CACHE_STORE=database
FILESYSTEM_DISK=local
LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Broadcasting / Reverb (websockets) -------------------------------------
BROADCAST_CONNECTION=reverb

# CHANGE THESE for production (any unique strings/ids will do).
REVERB_APP_ID=966046
REVERB_APP_KEY=change-me-app-key
REVERB_APP_SECRET=change-me-app-secret

# Server-to-server connection PHP uses to publish events to the reverb
# container — must stay http on the internal docker network.
REVERB_HOST=reverb
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081

# Frontend websocket target. Leave ALL THREE blank for the normal setup:
# the browser connects back to the page's own host through nginx /app, so the
# image stays host-independent. Only set these if reverb is exposed elsewhere.
REVERB_FRONTEND_HOST=
REVERB_FRONTEND_PORT=
REVERB_FRONTEND_SCHEME=

# --- Mail (optional) ---------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=${APP_NAME}
